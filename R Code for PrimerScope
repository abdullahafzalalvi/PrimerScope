# ----------------------------
# 1️⃣ Helper functions
# ----------------------------
calc_tm <- function(primer) {
  primer <- toupper(primer)
  len <- nchar(primer)
  nA <- str_count(primer,"A"); nT <- str_count(primer,"T")
  nG <- str_count(primer,"G"); nC <- str_count(primer,"C")
  if(len<14) tm <- (nA+nT)*2 + (nG+nC)*4
  else tm <- 64.9 + 41*(nG+nC-16.4)/len
  round(tm,1)
}

calc_gc <- function(primer) {
  primer <- toupper(primer)
  len <- nchar(primer)
  gc_count <- str_count(primer,"G")+str_count(primer,"C")
  round((gc_count/len)*100,1)
}

rev_complement <- function(primer) {
  paste(rev(strsplit(chartr("ATGC","TACG",toupper(primer)),"")[[1]]),collapse="")
}

check_binding <- function(primer, template, is_reverse=FALSE) {
  seq_to_search <- if(is_reverse) rev_complement(primer) else toupper(primer)
  loc <- str_locate(toupper(template), seq_to_search)
  if(is.na(loc[1])) return(NA)
  loc[1]
}

check_hairpin <- function(primer) {
  primer <- toupper(primer)
  rc <- rev_complement(primer)
  for(i in 4:(nchar(primer)-3)) if(str_detect(rc, substr(primer,1,i))) return(TRUE)
  FALSE
}

check_dimer <- function(fwd, rev) {
  rc <- rev_complement(rev)
  fwd <- toupper(fwd)
  for(i in 4:(nchar(fwd)-3)) if(str_detect(rc, substr(fwd,1,i))) return(TRUE)
  FALSE
}

