# ----------------------------
# 4️⃣ Generate report & return positions safely
# ----------------------------
generate_report <- function(fwd, rev, template, output_file) {
  sink(output_file)
  cat("===== PCR PRIMER CHECKER REPORT(BY ABDULLAH AFZAL ALVI,UL) =====\n\n")
  cat("Template Length:", nchar(template),"bp\n\n")
  
  # Forward
  bind_pos_f <- check_binding(fwd, template)
  cat("--- Forward Primer ---\n")
  cat("Sequence     :", fwd,"\nLength:", nchar(fwd),"bp\n")
  gc <- calc_gc(fwd); cat("GC Content   :", gc,"%\n")
  tm <- calc_tm(fwd); cat("Tm          :", tm,"°C\n")
  cat("Binding      :", if(!is.na(bind_pos_f)) paste("Found at position",bind_pos_f) else "Not found","\n")
  cat("Hairpin Risk :", if(check_hairpin(fwd)) "High" else "Low","\n\n")
  
  # Reverse
  bind_pos_r <- check_binding(rev, template, is_reverse=TRUE)
  cat("--- Reverse Primer ---\n")
  cat("Sequence     :", rev,"\nLength:", nchar(rev),"bp\n")
  gc <- calc_gc(rev); cat("GC Content   :", gc,"%\n")
  tm <- calc_tm(rev); cat("Tm          :", tm,"°C\n")
  cat("Binding      :", if(!is.na(bind_pos_r)) paste("Found at position",bind_pos_r) else "Not found","\n")
  cat("Hairpin Risk :", if(check_hairpin(rev)) "High" else "Low","\n\n")
  
  # Dimer & Amplicon
  cat("Primer Dimer Risk :", if(check_dimer(fwd,rev)) "High" else "Low","\n")
  if(!is.na(bind_pos_f) & !is.na(bind_pos_r)) {
    amp_size <- bind_pos_r + nchar(rev) - bind_pos_f + 1
    cat("Expected Amplicon Size :", amp_size,"bp\n")
  } else cat("Expected Amplicon Size : Cannot determine\n")
  cat("\n======================================\n")
  sink()
  cat("Report saved to", output_file,"\n")
  
  # Always return positions object
  list(fwd_pos=bind_pos_f, rev_pos=bind_pos_r, fwd_len=nchar(fwd), rev_len=nchar(rev), template_len=nchar(template))
}

positions <- generate_report(forward_primer, reverse_primer, template, report_file)

# ----------------------------
# 5️⃣ Visualization — only if positions exist
# ----------------------------
if(!is.na(positions$fwd_pos) & !is.na(positions$rev_pos)) {
  df <- data.frame(
    primer=c("Forward","Reverse"),
    start=c(positions$fwd_pos, positions$rev_pos),
    end=c(positions$fwd_pos+positions$fwd_len-1, positions$rev_pos+positions$rev_len-1)
  )
  p1 <- ggplot(df) + 
    geom_segment(aes(x=start,xend=end,y=primer,yend=primer,color=primer),size=5) +
    geom_text(aes(x=(start+end)/2,y=primer,label=paste0(start,"-",end)), color="white", vjust=-0.5) +
    xlim(0, positions$template_len+20) +
    labs(title="Primer Binding Positions", x="Template Position (bp)", y="Primer") +
    theme_minimal() + theme(legend.position="none")
  ggsave("results/primer_positions.png", p1, width=10,height=3)
  plot(p1)
  cat("Primer positions plot saved to results/primer_positions.png\n")
}

# ----------------------------
# 6️⃣ Additional Graphs: Sliding GC heatmap
# ----------------------------
window_size <- 10
gc_values <- sapply(1:(nchar(template)-window_size+1), function(i) {
  seq_window <- substr(template,i,i+window_size-1)
  calc_gc(seq_window)
})
heatmap_df <- data.frame(start=1:(nchar(template)-window_size+1), GC=gc_values)
p2 <- ggplot(heatmap_df, aes(x=start,y=1,fill=GC)) + 
  geom_tile() + scale_fill_gradient(low="lightyellow", high="red") +
  labs(title="Sliding Window GC Content Heatmap BY ABDULAH AFZAL ALVI", x="Template Position (bp)", y="", fill="GC%") +
  theme_minimal() + theme(axis.text.y=element_blank(), axis.ticks.y=element_blank())
